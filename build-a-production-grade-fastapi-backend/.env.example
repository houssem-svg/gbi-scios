APP_NAME=GBI-SCIOS API
ENVIRONMENT=local
API_V1_PREFIX=/api/v1

# ─── Database ───────────────────────────────────────────────────────────
# Local dev uses SQLite; production must use a Saudi-resident Postgres provider.
DATABASE_URL=sqlite:///./gbi_scios.db
# DATABASE_URL=postgresql+psycopg://gbi_scios:CHANGE_ME@<saudi-host>:5432/gbi_scios

UPLOAD_STORAGE_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=25
PARSING_LOG_DIR=storage/parsing_logs
COMPLIANCE_SCAN_LOG_DIR=storage/compliance_scan_logs
COMPLIANCE_FUZZY_MATCH_THRESHOLD=85

# ─── Auth ───────────────────────────────────────────────────────────────
# Generate a strong secret with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# DO NOT commit a real secret. The placeholder below is rejected at startup.
JWT_SECRET_KEY=replace-with-a-strong-64-char-secret-run-secrets-token-urlsafe-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ───────────────────────────────────────────────────────────────
# Comma-separated allow-list of frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Local Content Program (LCP) ────────────────────────────────────────
# 53.4% of Saudi payroll is recognized as local content (LCP methodology).
SAUDI_PAYROLL_RECOGNITION_FACTOR=0.534

# ─── Data Sovereignty (PDPL) ────────────────────────────────────────────
# When "in-kingdom", startup refuses any DB host not in the Saudi allow-list.
DATA_RESIDENCY=in-kingdom
SAUDI_DB_HOST_ALLOWLIST=localhost,127.0.0.1,postgres,db,.saudi.cloud,.saudicloud.com,.local
