APP_NAME=GBI-SCIOS API
ENVIRONMENT=local
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gbi_scios
UPLOAD_STORAGE_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=25
PARSING_LOG_DIR=storage/parsing_logs
COMPLIANCE_SCAN_LOG_DIR=storage/compliance_scan_logs
COMPLIANCE_FUZZY_MATCH_THRESHOLD=85

JWT_SECRET_KEY=change-me-to-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
